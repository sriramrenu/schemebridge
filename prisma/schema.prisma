generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String?
  state            String?
  gender           String?
  ageSegment       String?
  casteCategory    String?
  studentStatus    String?
  employmentStatus String?
  incomeBracket    String?
  otp              String?
  otpExpiry        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Scheme {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  summary          String
  category         String
  ministry         String
  stateScope       String?  

  // Structured Metadata for Matching
  targetGenders    String[] 
  targetEmployment String[] 
  targetStudent    Boolean  @default(false)
  targetCastes     String[] 
  
  // Vector Embeddings (384 dimensions for all-MiniLM-L6-v2)
  embedding        Unsupported("vector(384)")?

  createdAt        DateTime @default(now())
}
