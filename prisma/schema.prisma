generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String?
  state            String?
  gender           String?
  ageSegment       String?
  casteCategory    String?
  studentStatus    String?
  employmentStatus String?
  incomeBracket    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
